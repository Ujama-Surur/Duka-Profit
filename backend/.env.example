# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/duka-profit
#
# MongoDB Atlas:
# 1) Create a DB user in Atlas
# 2) Allow your IP in Network Access
# 3) Replace <username>, <password>, <cluster-url>, and <db-name>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority&appName=<app-name>

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRES_IN=30d

# License
LICENSE_SECRET=your-license-secret-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
